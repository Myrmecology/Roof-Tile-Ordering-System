# ============================================================
# ROOF TILE ORDERING SYSTEM — .gitignore
# Security-hardened | Includes YubiKey & secrets protection
# ============================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Build Output ---
dist/
dist-ssr/
build/
out/

# --- Environment & Secrets ---
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local
*.env
secrets.js
secrets.json
config.secret.*
**/secrets/**

# --- API Keys & Tokens ---
*.key
*.pem
*.p12
*.pfx
*.cert
*.crt
*.csr
*.der
api-keys.*
auth-tokens.*
credentials.*

# --- YubiKey & Hardware Security ---
*.ykpersonalization
*.yubikey
yubikey-config.*
yk-*.conf
gpg-keys/
pgp-keys/
.gnupg/
.yubiagent/
u2f_keys
fido_credentials
*.asc
*.gpg
*.pgp
private-keys-v1.d/
openpgp-revocs.d/

# --- SSH Keys ---
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
*.ppk
known_hosts
authorized_keys
ssh_config

# --- OS Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- VS Code ---
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.log
.history/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Testing & Coverage ---
coverage/
*.lcov
.nyc_output/

# --- Misc Dev Tools ---
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.tsbuildinfo

# --- Local Data & Storage ---
local-data/
*.sqlite
*.sqlite3
*.db

# --- Temporary Files ---
*.tmp
*.temp
*.swp
*.swo
*~
