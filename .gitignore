# ============================================================
# ROOF TILE ORDERING SYSTEM — .gitignore
# ============================================================

# ------------------------------------------------------------
# ENVIRONMENT & SECRETS
# ------------------------------------------------------------
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
*.env
secrets.json
secrets.yaml
secrets.toml
config/secrets.*

# ------------------------------------------------------------
# YUBIKEY & HARDWARE SECURITY
# ------------------------------------------------------------
*.pgp
*.gpg
*.asc
*.pem
*.p12
*.pfx
*.key
*.crt
*.cer
*.der
*.csr
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
id_ecdsa
id_ecdsa.*
*.ppk
.gnupg/
.ssh/
yubikey-*.conf
yubikey.conf
ykman*
piv-*.pem

# ------------------------------------------------------------
# API KEYS & TOKENS
# ------------------------------------------------------------
*.token
*.secret
api_keys.*
credentials.*
auth.json
token.json
oauth*.json
service_account*.json

# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.Python
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
htmlcov/
nosetests.xml
coverage.xml
*.cover
*.log
.hypothesis/

# Virtual Environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
.virtualenv/
Pipfile.lock

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
data/*.db
data/*.sqlite
data/*.sqlite3

# ------------------------------------------------------------
# VS CODE
# ------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.vscode/*.code-snippets
.history/
*.vsix

# ------------------------------------------------------------
# WINDOWS SYSTEM FILES
# ------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk
*.stackdump

# ------------------------------------------------------------
# NODE / TAILWIND BUILD ARTIFACTS
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/
dist/
.parcel-cache/
.cache/

# ------------------------------------------------------------
# LOGS & TEMP FILES
# ------------------------------------------------------------
*.log
logs/
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# ------------------------------------------------------------
# OS GENERAL
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes